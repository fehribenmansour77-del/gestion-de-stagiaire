# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gestion_stagiaires
DB_USER=root
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=gestion-stagiaires-secret-key-change-in-production
JWT_EXPIRY=24h

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration (for password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@gias.com
SMTP_PASSWORD=
EMAIL_FROM=noreply@gias.com

# Application URL (for generating links)
APP_URL=http://localhost:3000

# Twilio Configuration (for SMS OTP via Verify API)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid
